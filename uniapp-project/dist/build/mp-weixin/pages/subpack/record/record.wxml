<view class="record-page data-v-d1d5a5de"><view wx:if="{{a}}" class="record-list data-v-d1d5a5de"><view wx:for="{{b}}" wx:for-item="record" wx:key="g" class="record-card data-v-d1d5a5de"><view class="record-header data-v-d1d5a5de"><text class="record-date data-v-d1d5a5de">{{record.a}}</text><text class="record-count data-v-d1d5a5de">{{record.b}} 件</text></view><view class="record-goods data-v-d1d5a5de"><view wx:for="{{record.c}}" wx:for-item="item" wx:key="d" class="goods-row data-v-d1d5a5de"><text class="goods-name data-v-d1d5a5de">{{item.a}}</text><text class="goods-qty data-v-d1d5a5de">×{{item.b}}</text><text class="goods-price data-v-d1d5a5de">¥{{item.c}}</text></view><view wx:if="{{record.d}}" class="more-goods data-v-d1d5a5de"><text class="data-v-d1d5a5de">...还有 {{record.e}} 件商品</text></view></view><view class="record-footer data-v-d1d5a5de"><text class="total-label data-v-d1d5a5de">合计：</text><text class="total-price data-v-d1d5a5de">¥{{record.f}}</text></view></view></view><view wx:else class="empty-tip data-v-d1d5a5de"><image src="{{c}}" class="empty-img data-v-d1d5a5de"></image><text class="empty-text data-v-d1d5a5de">暂无出库记录</text></view></view>